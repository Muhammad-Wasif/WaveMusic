<Window x:Class="WaveMusic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WaveMusic.Converters"
        Title="WaveMusic" Height="750" Width="1280"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BgBrush}"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        SourceInitialized="Window_SourceInitialized">

    <Window.Resources>
        <conv:BoolToPlayIconConverter x:Key="PlayIcon"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:NullToCollapsedConverter x:Key="NullCollapsed"/>
        <conv:TimeSpanToDoubleConverter x:Key="TsDouble"/>
        <conv:TimeSpanToStringConverter x:Key="TsString"/>
        <conv:BoolToColorConverter x:Key="BoolColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>   <!-- Custom title bar -->
            <RowDefinition Height="*"/>    <!-- Main content -->
            <RowDefinition Height="80"/>   <!-- Player bar -->
        </Grid.RowDefinitions>

        <!-- ══════ TITLE BAR ══════ -->
        <Border Grid.Row="0" Background="#0A0A0A" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="24" Height="24" Margin="0,0,4,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF0033" Offset="0"/>
                                <GradientStop Color="#AA0022" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="▶" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="-18,0,0,0"/>
                    <TextBlock Text="WaveMusic" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Search Bar -->
                <Border Grid.Column="1" Background="#303030" CornerRadius="20"
                        VerticalAlignment="Center" MaxWidth="500" Margin="20,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Foreground="#888888"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 Background="Transparent" Foreground="White"
                                 BorderThickness="0" FontSize="13" Padding="0,8,12,8"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="White"
                                 KeyDown="SearchBox_KeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <Label Content="Search songs, albums, artists" Foreground="Gray" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource IconBtn}" Width="32" Height="32" Content="—"
                            Foreground="White" FontSize="14" Click="MinimizeBtn_Click"/>
                    <Button Style="{StaticResource IconBtn}" Width="32" Height="32" Content="□"
                            Foreground="White" FontSize="14" Click="MaximizeBtn_Click"/>
                    <Button Style="{StaticResource IconBtn}" Width="32" Height="32" Content="✕"
                            Foreground="White" FontSize="14" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ MAIN CONTENT ══════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Background="{StaticResource SidebarBrush}" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nav Items -->
                    <StackPanel Margin="8,12,8,0">
                        <Button x:Name="BtnHome" Style="{StaticResource NavBtnActive}"
                                Click="Nav_Click" Tag="Home" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠" FontSize="18" Width="28" VerticalAlignment="Center"/>
                                <TextBlock Text="Home" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnExplore" Style="{StaticResource NavBtn}"
                                Click="Nav_Click" Tag="Explore" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="18" Width="28" VerticalAlignment="Center"/>
                                <TextBlock Text="Explore" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnLibrary" Style="{StaticResource NavBtn}"
                                Click="Nav_Click" Tag="Library" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📚" FontSize="18" Width="28" VerticalAlignment="Center"/>
                                <TextBlock Text="Library" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnUpgrade" Style="{StaticResource NavBtn}"
                                Click="Nav_Click" Tag="Upgrade" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭐" FontSize="18" Width="28" VerticalAlignment="Center"/>
                                <TextBlock Text="Upgrade" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="4,12"/>

                        <!-- New Playlist Button -->
                        <Button Style="{StaticResource NavBtn}" Click="NewPlaylist_Click" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" Background="{StaticResource Card2Brush}"
                                        CornerRadius="4" Margin="0,0,8,0">
                                    <TextBlock Text="+" FontSize="16" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="New playlist" FontSize="14"
                                           Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Playlist list (scrollable) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,4,8,8">
                        <StackPanel x:Name="PlaylistSidePanel">
                            <!-- Liked Music -->
                            <Button Style="{StaticResource NavBtn}" Margin="0,1" Click="Playlist_Click" Tag="Liked Music">
                                <StackPanel>
                                    <TextBlock Text="Liked Music" FontSize="13"
                                               Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="★ Auto playlist" FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Margin="0,1" Click="Playlist_Click" Tag="OST">
                                <StackPanel>
                                    <TextBlock Text="Pakistani Drama OST..." FontSize="13"
                                               Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    <TextBlock Text="PakMusicHD" FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavBtn}" Margin="0,1" Click="Playlist_Click" Tag="Episodes">
                                <StackPanel>
                                    <TextBlock Text="Episodes for Later" FontSize="13"
                                               Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Auto playlist" FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <Border Grid.Column="1" Background="{StaticResource BgBrush}" ClipToBounds="True">
                <ContentControl x:Name="ContentArea"/>
            </Border>
        </Grid>

        <!-- ══════ PLAYER BAR ══════ -->
        <Border Grid.Row="2" Background="{StaticResource PlayerBrush}">
            <Border.BorderBrush>
                <SolidColorBrush Color="#2E2E2E"/>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness Top="1"/>
            </Border.BorderThickness>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Now Playing Info -->
                <Grid VerticalAlignment="Center" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="52" Height="52" CornerRadius="4" ClipToBounds="True"
                            Background="{StaticResource Card2Brush}">
                        <Grid>
                            <Image x:Name="NowPlayingThumb" Stretch="UniformToFill"/>
                            <TextBlock x:Name="NowPlayingDefault" Text="♪" FontSize="20"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                        <TextBlock x:Name="NowPlayingTitle" Text="Not Playing"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="NowPlayingArtist" Text="Select a song"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource IconBtn}" Content="♥"
                            FontSize="18" Foreground="{StaticResource SecondaryTextBrush}"
                            Width="32" Height="32" Click="Like_Click"/>
                </Grid>

                <!-- Center Controls -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Control Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Button x:Name="ShuffleBtn" Style="{StaticResource IconBtn}"
                                Content="🔀" FontSize="16" Width="36" Height="36"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Click="Shuffle_Click" ToolTip="Shuffle"/>
                        <Button Style="{StaticResource IconBtn}" Content="⏮"
                                FontSize="20" Width="40" Height="40"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                Click="Prev_Click" ToolTip="Previous"/>
                        <Button x:Name="PlayPauseBtn" Style="{StaticResource IconBtn}"
                                Width="48" Height="48" FontSize="20"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                Click="PlayPause_Click" ToolTip="Play/Pause"
                                Background="#FF0033">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            CornerRadius="24" Width="48" Height="48">
                                        <TextBlock x:Name="PlayIcon" Text="▶" FontSize="18"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#CC0022"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource IconBtn}" Content="⏭"
                                FontSize="20" Width="40" Height="40"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                Click="Next_Click" ToolTip="Next"/>
                        <Button x:Name="RepeatBtn" Style="{StaticResource IconBtn}"
                                Content="🔁" FontSize="16" Width="36" Height="36"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Click="Repeat_Click" ToolTip="Repeat"/>
                    </StackPanel>

                    <!-- Progress Bar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PositionText" Text="0:00"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="ProgressSlider" Grid.Column="1"
                                Style="{StaticResource PlayerSlider}"
                                Minimum="0" Maximum="1"
                                IsEnabled="True"
                                ValueChanged="Progress_Changed"
                                PreviewMouseDown="Progress_MouseDown"
                                PreviewMouseUp="Progress_MouseUp"/>
                        <TextBlock x:Name="DurationText" Grid.Column="2" Text="0:00"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- Right Controls: Volume + Queue -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0">

                    <Button Style="{StaticResource IconBtn}" Content="📋"
                            FontSize="18" Width="36" Height="36"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            Click="Queue_Click" ToolTip="Queue" Margin="0,0,4,0"/>

                    <TextBlock Text="🔊" FontSize="16" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{StaticResource SecondaryTextBrush}"/>

                    <Slider x:Name="VolumeSlider" Style="{StaticResource PlayerSlider}"
                            Width="100" VerticalAlignment="Center"
                            Minimum="0" Maximum="1" Value="0.8"
                            ValueChanged="Volume_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
