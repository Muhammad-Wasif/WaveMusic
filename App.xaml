<Application x:Class="WaveMusic.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Brushes -->
            <SolidColorBrush x:Key="BgBrush" Color="#0F0F0F"/>
            <SolidColorBrush x:Key="SidebarBrush" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="CardBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="Card2Brush" Color="#272727"/>
            <SolidColorBrush x:Key="HoverBrush" Color="#3D3D3D"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF0033"/>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
            <SolidColorBrush x:Key="PlayerBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="ActiveNavBrush" Color="#272727"/>
            <SolidColorBrush x:Key="ProgressBrush" Color="#FF0033"/>
            <SolidColorBrush x:Key="ProgressBgBrush" Color="#3D3D3D"/>
            <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="BorderBrush2" Color="#2E2E2E"/>

            <!-- ScrollBar Style -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#555555" CornerRadius="3"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ScrollViewer Style -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!-- Generic Button Style -->
            <Style x:Key="IconBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="50" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#555555"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nav Button Style -->
            <Style x:Key="NavBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Active Nav Button -->
            <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
                <Setter Property="Background" Value="#272727"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            </Style>

            <!-- Chip/Pill Button -->
            <Style x:Key="ChipBtn" TargetType="Button">
                <Setter Property="Background" Value="#272727"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="16" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}" 
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Slider Style for Progress and Volume -->
            <Style x:Key="PlayerSlider" TargetType="Slider">
                <Setter Property="IsSelectionRangeEnabled" Value="True"/>
                <Setter Property="SelectionStart" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center" Height="18">
                                <!-- Background track -->
                                <Border Height="4" CornerRadius="2"
                                        Background="{StaticResource ProgressBgBrush}"
                                        VerticalAlignment="Center"/>
                                <!-- Progress fill using Canvas + Rectangle (WPF native PART_SelectionRange) -->
                                <Canvas VerticalAlignment="Center" Height="4">
                                    <Rectangle x:Name="PART_SelectionRange"
                                               Height="4" Fill="{StaticResource ProgressBrush}"
                                               RadiusX="2" RadiusY="2"/>
                                </Canvas>
                                <!-- Track with Thumb and invisible repeat buttons -->
                                <Track x:Name="PART_Track" VerticalAlignment="Center">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Background="Transparent" Opacity="0"
                                                      BorderThickness="0" Focusable="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="12" Height="12" VerticalAlignment="Center">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse x:Name="thumbCircle"
                                                             Fill="White" Width="12" Height="12"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="thumbCircle" Property="Width" Value="14"/>
                                                            <Setter TargetName="thumbCircle" Property="Height" Value="14"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Background="Transparent" Opacity="0"
                                                      BorderThickness="0" Focusable="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Accent Button -->
            <Style x:Key="AccentBtn" TargetType="Button">
                <Setter Property="Background" Value="#FF0033"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="24,12"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#CC0028"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox Search Style -->
            <Style x:Key="SearchBox" TargetType="TextBox">
                <Setter Property="Background" Value="#303030"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
