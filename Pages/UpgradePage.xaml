<UserControl x:Class="WaveMusic.Pages.UpgradePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <!-- Background gradient -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F1A0F" Offset="0"/>
                    <GradientStop Color="#1A0A2E" Offset="0.5"/>
                    <GradientStop Color="#2E0A1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" Margin="24,60,24,60">

                <!-- Logo -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Ellipse Width="40" Height="40" Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF0033" Offset="0"/>
                                <GradientStop Color="#CC0022" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="▶" FontSize="20" Foreground="White"
                               VerticalAlignment="Center" Margin="-30,0,0,0"/>
                    <TextBlock Text="WaveMusic" FontSize="22" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Main Headline -->
                <TextBlock FontSize="36" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="700" Margin="0,0,0,12">
                    Get Wave Premium to listen<LineBreak/>ad-free, offline &amp; with your screen off
                </TextBlock>

                <TextBlock FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32">
                    1-month trial for PKR 0 · Then PKR 349/month · Cancel anytime
                </TextBlock>

                <Button Content="Try 1 month for PKR 0" Style="{StaticResource AccentBtn}"
                        HorizontalAlignment="Center" Margin="0,0,0,48"
                        Click="TryFree_Click"
                        Background="#4FC3F7" Foreground="Black" FontSize="16" Padding="32,14"/>

                <!-- Features Grid -->
                <TextBlock Text="What you get with Wave Premium" FontSize="20" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <UniformGrid Columns="2" MaxWidth="700" HorizontalAlignment="Center">

                    <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="8">
                        <StackPanel>
                            <TextBlock Text="🚫" FontSize="32" Margin="0,0,0,12"/>
                            <TextBlock Text="Ad-free music" FontSize="16" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="Listen without interruption. No ads, ever."
                                       FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="8">
                        <StackPanel>
                            <TextBlock Text="📥" FontSize="32" Margin="0,0,0,12"/>
                            <TextBlock Text="Download music" FontSize="16" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="Save songs and listen offline, anywhere."
                                       FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="8">
                        <StackPanel>
                            <TextBlock Text="📱" FontSize="32" Margin="0,0,0,12"/>
                            <TextBlock Text="Screen off playback" FontSize="16" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="Keep music playing with the screen locked."
                                       FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="8">
                        <StackPanel>
                            <TextBlock Text="🎵" FontSize="32" Margin="0,0,0,12"/>
                            <TextBlock Text="Background play" FontSize="16" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="Switch apps while music keeps playing."
                                       FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Pricing -->
                <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="0,32,0,0" MaxWidth="700">
                    <StackPanel>
                        <TextBlock Text="Plans" FontSize="18" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#272727" CornerRadius="8" Padding="20" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Individual" FontSize="16" FontWeight="Bold"
                                               Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="PKR 349/month" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="After 1-month free trial" FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,12"/>
                                    <TextBlock Text="✓ All premium features" FontSize="13" Foreground="#AAFFAA"/>
                                    <TextBlock Text="✓ 1 account" FontSize="13" Foreground="#AAFFAA"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#272727" CornerRadius="8" Padding="20" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Family" FontSize="16" FontWeight="Bold"
                                               Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="PKR 549/month" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="After 1-month free trial" FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,12"/>
                                    <TextBlock Text="✓ All premium features" FontSize="13" Foreground="#AAFFAA"/>
                                    <TextBlock Text="✓ Up to 6 accounts" FontSize="13" Foreground="#AAFFAA"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
