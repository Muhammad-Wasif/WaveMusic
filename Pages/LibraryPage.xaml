<UserControl x:Class="WaveMusic.Pages.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WaveMusic.Converters"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:NullToCollapsedConverter x:Key="NullCollapsed"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter Tabs + Sort -->
        <Grid Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <WrapPanel>
                <Button x:Name="BtnAll" Content="All" Style="{StaticResource ChipBtn}"
                        Margin="0,0,8,8" Click="FilterBtn_Click" Tag="All"
                        Background="#FF0033"/>
                <Button x:Name="BtnPlaylists" Content="Playlists" Style="{StaticResource ChipBtn}"
                        Margin="0,0,8,8" Click="FilterBtn_Click" Tag="Playlists"/>
                <Button x:Name="BtnSongs" Content="Songs" Style="{StaticResource ChipBtn}"
                        Margin="0,0,8,8" Click="FilterBtn_Click" Tag="Songs"/>
                <Button x:Name="BtnAlbums" Content="Albums" Style="{StaticResource ChipBtn}"
                        Margin="0,0,8,8" Click="FilterBtn_Click" Tag="Albums"/>
                <Button x:Name="BtnArtists" Content="Artists" Style="{StaticResource ChipBtn}"
                        Margin="0,0,8,8" Click="FilterBtn_Click" Tag="Artists"/>
            </WrapPanel>
            <Button Grid.Column="1" Content="Recent activity ⌄" Style="{StaticResource ChipBtn}"
                    Background="{StaticResource Card2Brush}"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <StackPanel Margin="24,0,24,24">

                <!-- Empty state / Add music prompt -->
                <Border x:Name="EmptyState" Background="{StaticResource Card2Brush}"
                        CornerRadius="12" Padding="32" Margin="0,16,0,24">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Add your local music folder" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Songs and images with the same filename will be matched automatically."
                                   FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"
                                   TextAlignment="Center" Margin="0,0,0,20"/>
                        <Button Content="Browse Folder" Style="{StaticResource AccentBtn}"
                                HorizontalAlignment="Center" Click="BrowseFolder_Click"/>
                    </StackPanel>
                </Border>

                <!-- Playlists Section -->
                <StackPanel x:Name="PlaylistSection">
                    <TextBlock Text="Playlists" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="PlaylistGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="160" Margin="0,0,20,20" Cursor="Hand" Background="Transparent">
                                    <StackPanel>
                                        <Border Width="160" Height="160" CornerRadius="8" ClipToBounds="True"
                                                Background="{StaticResource Card2Brush}">
                                            <Grid>
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                                <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding Cover, Converter={StaticResource NullVis}}"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,8,0,2" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                        <TextBlock Text="{Binding TrackCount}"
                                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Songs Section -->
                <StackPanel x:Name="SongsSection">
                    <Grid Margin="0,8,0,12">
                        <TextBlock Text="Songs" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </Grid>
                    <!-- Header row -->
                    <Grid Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="TITLE" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="12,0"/>
                        <TextBlock Grid.Column="3" Text="ALBUM" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Grid.Column="4" Text="⏱" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" HorizontalAlignment="Right"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="0,0,0,4"/>
                    <ItemsControl x:Name="SongsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonUp="Song_Click" Margin="0,1">
                                    <Border x:Name="rowBg" CornerRadius="4" Padding="8,7">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1F1F1F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TrackNum}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4"
                                                    ClipToBounds="True" Background="{StaticResource Card2Brush}">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                                    <TextBlock Text="🎵" FontSize="18" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding Thumbnail, Converter={StaticResource NullVis}}"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding Album}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="4" Text="{Binding DurationString}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
