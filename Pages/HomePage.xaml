<UserControl x:Class="WaveMusic.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WaveMusic.Converters"
             Background="{StaticResource BgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:NullToCollapsedConverter  x:Key="NullCol"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Search + Upload bar -->
            <RowDefinition Height="*"/>      <!-- Song grid content -->
        </Grid.RowDefinitions>

        <!-- ══ TOP BAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                Padding="24,12" BorderThickness="0,0,0,1">
            <Border.BorderBrush><SolidColorBrush Color="#2E2E2E"/></Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Live search box -->
                <Border Background="#272727" CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="14" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="#888"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 Background="Transparent" Foreground="White"
                                 BorderThickness="0" FontSize="13"
                                 Padding="0,10" VerticalContentAlignment="Center"
                                 CaretBrush="White" TextChanged="SearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="H" TileMode="None" Opacity="0.35"
                                                     Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <Label Content="Search songs, artists, albums…"
                                                       Foreground="#AAAAAA" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource H}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button Grid.Column="2" x:Name="ClearSearch" Content="✕"
                                FontSize="12" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#888" Cursor="Hand"
                                Visibility="Collapsed" Click="ClearSearch_Click"/>
                    </Grid>
                </Border>

                <!-- Add individual files -->
                <Button Grid.Column="1" Click="UploadFiles_Click" Margin="12,0,0,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#272727" CornerRadius="20" Padding="14,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎵" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Add Songs" FontSize="13" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Add folder -->
                <Button Grid.Column="2" Click="UploadFolder_Click" Margin="8,0,0,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF0033" CornerRadius="20" Padding="14,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Add Folder" FontSize="13" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#CC0022"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ══ CONTENT ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Empty library state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Visibility="Visible">
                <TextBlock Text="🎵" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Your library is empty"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Click 'Add Songs' to pick files, or 'Add Folder' to scan a folder."
                           FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="400" TextAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="💾  Songs are saved automatically — they'll still be here next launch."
                           FontSize="12" Foreground="#555"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>

            <!-- No search results -->
            <StackPanel x:Name="NoResults" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="🔍" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock x:Name="NoResultsText" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ── SONG GRID (vertical scroll, wraps into rows of 8) ── -->
            <ScrollViewer x:Name="MainScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="Collapsed">
                <StackPanel Margin="24,16,24,32">

                    <!-- Section header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="SectionTitle" Text="Your Music"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock x:Name="SongCountText"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Scroll to top / bottom arrows -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="▲" Style="{StaticResource IconBtn}"
                                    Width="36" Height="36" FontSize="14"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    Click="ScrollUp_Click" Margin="0,0,4,0"
                                    ToolTip="Scroll up one row"/>
                            <Button Content="▼" Style="{StaticResource IconBtn}"
                                    Width="36" Height="36" FontSize="14"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    Click="ScrollDown_Click"
                                    ToolTip="Scroll down one row"/>
                        </StackPanel>
                    </Grid>

                    <!--
                        KEY FIX: No HorizontalScrollViewer wrapping the ItemsControl.
                        The WrapPanel gets the ACTUAL width of its container, so it
                        wraps cards into multiple rows (8 per row at 1280px wide).
                    -->
                    <ItemsControl x:Name="SongGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- WrapPanel wraps when it runs out of width -->
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="160" Margin="0,0,14,20"
                                        Cursor="Hand" Background="Transparent"
                                        MouseLeftButtonUp="SongCard_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <!-- Album art / thumbnail -->
                                        <Border Width="160" Height="160" CornerRadius="8"
                                                ClipToBounds="True"
                                                Background="{StaticResource Card2Brush}">
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill"/>
                                                <!-- Placeholder when no art -->
                                                <Border Background="#1A1A1A"
                                                        Visibility="{Binding Thumbnail, Converter={StaticResource NullVis}}">
                                                    <TextBlock Text="♪" FontSize="54" Foreground="#2A2A2A"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Bottom gradient -->
                                                <Border CornerRadius="0,0,8,8" IsHitTestVisible="False">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="Transparent" Offset="0.5"/>
                                                            <GradientStop Color="#CC000000" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <!-- Now Playing overlay -->
                                                <Border CornerRadius="8" Background="#99000000"
                                                        Visibility="{Binding IsPlaying, Converter={StaticResource BoolVis}}">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="▶" FontSize="28" Foreground="#FF0033"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Playing" FontSize="11"
                                                                   Foreground="White" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- SAMPLE badge -->
                                                <Border Visibility="{Binding IsSample, Converter={StaticResource BoolVis}}"
                                                        Background="#99FF0033" CornerRadius="4"
                                                        Padding="5,2" HorizontalAlignment="Left"
                                                        VerticalAlignment="Top" Margin="6,6,0,0">
                                                    <TextBlock Text="SAMPLE" FontSize="9"
                                                               Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- Text info -->
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Margin="0,8,0,2"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160" ToolTip="{Binding Title}"/>
                                        <TextBlock Text="{Binding Artist}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160" ToolTip="{Binding Artist}"/>
                                        <TextBlock Text="{Binding DurationString}"
                                                   Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Mood chips -->
                    <TextBlock Text="Browse by mood" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" Margin="0,24,0,12"/>
                    <WrapPanel>
                        <Button Content="Relax"     Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Feel good" Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Workout"   Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Energize"  Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Party"     Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Romance"   Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Sad"       Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Focus"     Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                        <Button Content="Sleep"     Style="{StaticResource ChipBtn}" Margin="0,0,8,8" Click="MoodChip_Click"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
