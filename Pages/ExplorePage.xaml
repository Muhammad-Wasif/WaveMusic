<UserControl x:Class="WaveMusic.Pages.ExplorePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20">

            <!-- Top Feature Buttons -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource Card2Brush}" CornerRadius="8"
                        Padding="20,18" Cursor="Hand" MouseLeftButtonUp="NewReleases_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎵" FontSize="22" Margin="0,0,12,0"/>
                        <TextBlock Text="New releases" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource Card2Brush}" CornerRadius="8"
                        Padding="20,18" Cursor="Hand" MouseLeftButtonUp="Charts_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈" FontSize="22" Margin="0,0,12,0"/>
                        <TextBlock Text="Charts" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{StaticResource Card2Brush}" CornerRadius="8"
                        Padding="20,18" Cursor="Hand" MouseLeftButtonUp="Moods_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D3D3D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="😊" FontSize="22" Margin="0,0,12,0"/>
                        <TextBlock Text="Moods &amp; genres" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- New albums & singles -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="New albums &amp; singles" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <Button Grid.Column="1" Content="More" Style="{StaticResource ChipBtn}"
                        Background="Transparent" Foreground="{StaticResource PrimaryTextBrush}"/>
            </Grid>

            <ItemsControl x:Name="NewReleasesPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="0,0,20,24" Cursor="Hand" Background="Transparent"
                                MouseLeftButtonUp="AlbumCard_Click">
                            <StackPanel>
                                <Border Width="160" Height="160" CornerRadius="8" ClipToBounds="True"
                                        Background="{StaticResource Card2Brush}">
                                    <Grid>
                                        <TextBlock Text="{Binding Glyph}" FontSize="48"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <Border>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{Binding GradColor1}" Offset="0"/>
                                                    <GradientStop Color="{Binding GradColor2}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding ShortTitle}" FontSize="16" FontWeight="Bold"
                                                   Foreground="White" TextWrapping="Wrap" Margin="10"
                                                   VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,8,0,2"
                                           TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                <TextBlock Text="{Binding SubTitle}" Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Trending Section -->
            <TextBlock Text="Trending" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,8,0,16"/>
            <ItemsControl x:Name="TrendingList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent" Cursor="Hand" Margin="0,2">
                            <Border x:Name="rb" CornerRadius="4" Padding="8,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1F1F1F"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Rank}" Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4"
                                            ClipToBounds="True" Background="{StaticResource Card2Brush}" Margin="0,0,0,0">
                                        <TextBlock Text="{Binding Glyph}" FontSize="20" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontSize="14" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="{Binding Trend}"
                                               Foreground="#44FF44" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                                </Grid>
                            </Border>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
